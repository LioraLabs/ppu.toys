# Cookfile for ppu.toys — a ShaderToy-style web playground for an emulated SNES PPU.
#
# Monorepo shape: a pure, headless Rust core (crates/ppu-core) compiled to WASM via
# wasm-pack, consumed by a React + Vite app (web/) behind the `PpuCore` TS seam;
# plus the site backend, a single axum binary (crates/ppu-server) imported as the
# `server` module below.
#
#   ── build ──────────────────────────────────────────────────────────────────
#   cook             full build (default): WASM module + web/dist + server
#   cook build       same as above
#   cook wasm        (re)build the WASM module into web/src/wasm/pkg
#   cook web         production web build -> web/dist
#   cook deps        install web/node_modules
#   cook server.build  compile the axum backend (crates/ppu-server)
#
#   ── run ──────────────────────────────────────────────────────────────────────
#   cook dev         Vite dev server (builds the WASM core first)
#   cook server.run  boot the backend serving web/dist + the live API
#
#   ── component workflow (Ladle catalog + fixtures + MSW) ──────────────────────
#   cook ladle       Ladle component catalog — dev server, iterate a component in
#                    isolation (no backend, no wasm boot for presentational stories)
#   cook catalog     static catalog build -> web/build (cached directory output)
#   cook shoot       screenshot one story -> web/.shots (STORY=<story-id>, e.g.
#                    STORY=components--toycard--default cook shoot). Needs a one-time
#                    `cd web && npx playwright install chromium`.
#   cook dev-offline Vite dev with the whole app mocked by MSW — no backend running
#                    (VITE_MSW=1). Pages populate from web/src/mocks handlers.
#
#   ── deploy/ops (production operations) ────────────────────────────────────
#   cook deploy.ship      trigger the CI deploy (gh workflow run deploy.yml)
#   cook deploy.rollback  swap back to the previous binary (needs DEPLOY_HOST/USER)
#   cook deploy.health    curl the live /api/health (PPU_BASE_URL override)
#   cook deploy.logs      follow the server journal on the box (DEPLOY_HOST/USER)
#
#   ── verify ─────────────────────────────────────────────────────────────────
#   cook test-core   cargo test (core unit + golden framebuffer compare)
#   cook test-web    vitest
#   cook server.test cargo test -p ppu-server (backend suites)
#   cook typecheck   tsc --noEmit over the web app
#   cook check       typecheck + all three test suites (pre-commit umbrella)
#   cook fmt         cargo fmt
#
#   ── housekeeping ─────────────────────────────────────────────────────────────
#   cook clean       remove build artifacts (target, dist, wasm pkg, .cook cache)
#   cook distclean   clean + remove web/node_modules
#
# Caching: all three generated artifacts are content-cached recipes, so a no-op
# `cook build` is ~0s and `clean` + rebuild restores from cache.
#   - `wasm`  declares its files explicitly (its pkg lives inside web's source tree,
#             so a globbed directory output would collide with web's `web/src/**`
#             ingredient globs).
#   - `deps`, `web`, and `catalog` use DIRECTORY outputs (trailing `/`). Safe now that
#             cook preserves symlinks + file modes on restore: node_modules'
#             `.bin/*` relative symlinks and Vite's content-hashed dist both round-trip
#             faithfully. Trade-off: a `deps` cache MISS (lockfile changed) empties
#             node_modules and does a full `npm install`; a cache HIT restores the tree
#             from the store. deps for THIS repo is npm (relative, in-tree symlinks) —
#             a pnpm repo (global-store hardlinks) would not be portable; keep it local.
#
# Cook gotcha: one command per line; a multi-step shell line needs `sh -c "a && b"`.

# ── MODULES: the axum backend lives in its own imported Cookfile, referenced
#    as server.build / server.test / server.run. The deploy/ production operations
#    come in as deploy.ship / rollback / health / logs.
import server ./crates/ppu-server
import deploy ./deploy

# ── WASM: rebuild the module only when the Rust core or its manifests change. The
#    files Vite + tsc consume are declared explicitly (so web forms file-level edges
#    to them). wasm-pack's --out-dir is relative to the crate dir.
recipe wasm
    ingredients "crates/ppu-core/src/**/*.rs" "crates/ppu-core/Cargo.toml" "Cargo.toml" "Cargo.lock"
    cook "web/src/wasm/pkg/ppu_core.js"
         "web/src/wasm/pkg/ppu_core_bg.wasm"
         "web/src/wasm/pkg/ppu_core.d.ts"
         "web/src/wasm/pkg/ppu_core_bg.wasm.d.ts" {
        wasm-pack build crates/ppu-core --target web --out-dir ../../web/src/wasm/pkg
    }

# ── DEPS: install node_modules as a cached directory output, keyed on the manifest
#    + lockfile. Relative `.bin/*` symlinks and exec bits round-trip.
recipe deps
    ingredients "web/package.json" "web/package-lock.json"
    cook "web/node_modules/" {
        npm --prefix web install --no-audit --no-fund
    }

# ── WEB: production bundle -> web/dist (cached directory output). Inputs are web's
#    sources/config, the lockfile (so a dep bump reaches the bundle), and the two
#    wasm pkg files Vite bundles (so a Rust change does too). cook owns the wasm
#    rebuild via the dep edge, so `build:app` (tsc + vite build) skips it.
recipe web: wasm deps
    ingredients "web/src/**/*.ts" "web/src/**/*.tsx" "web/index.html"
                "web/vite.config.ts" "web/tsconfig.json" "web/tsconfig.node.json"
                "web/package.json" "web/package-lock.json"
                "web/src/wasm/pkg/ppu_core.js" "web/src/wasm/pkg/ppu_core_bg.wasm"
    cook "web/dist/" {
        npm --prefix web run build:app
    }

# ── CATALOG: the Ladle component catalog as a static, cached bundle -> web/build.
#    Same input surface as `web` (stories/fixtures/mocks live under web/src, so the
#    src globs already cover them) plus the `.ladle/` config and `public/` (the MSW
#    worker Ladle serves). Depends on `wasm` because a story that imports the studio
#    transport transitively imports the wasm pkg module — Vite must resolve that file
#    even though presentational stories never call initCore(). `shoot` reuses this.
recipe catalog: wasm deps
    ingredients "web/src/**/*.ts" "web/src/**/*.tsx"
                "web/.ladle/**/*" "web/public/**/*"
                "web/vite.config.ts" "web/tsconfig.json" "web/tsconfig.node.json"
                "web/package.json" "web/package-lock.json"
                "web/src/wasm/pkg/ppu_core.js" "web/src/wasm/pkg/ppu_core_bg.wasm"
    cook "web/build/" {
        npm --prefix web run ladle:build
    }

# ── BUILD: the default target — the whole stack. server.build is an order-only
#    fence (it produces nothing the web build reads) kept so `cook build` compiles
#    the backend too.
recipe build: web server.build

# ── DEV SERVER: long-running, interactive. Builds the WASM core first — the app
#    has no mock fallback, so it can't render without it.
chore dev: wasm deps
    npm --prefix web run dev

# ── DEV (OFFLINE): the same Vite dev server, but MSW intercepts every API call so
#    the whole app boots with no backend — handlers in web/src/mocks serve fixtures.
chore dev-offline: wasm deps
    sh -c 'VITE_MSW=1 npm --prefix web run dev'

# ── COMPONENT WORKFLOW: Ladle catalog (long-running, interactive, hot-reloads).
#    Iterate any component in isolation from a fixture; wasm-free for presentational
#    stories (deps on `wasm` only so studio stories that reference the pkg resolve).
chore ladle: wasm deps
    npm --prefix web run ladle

# ── SHOOT: render one story to a PNG under web/.shots for a tight (agent) visual
#    loop. STORY is required (env-driven, like the deploy chores); the shoot script
#    screenshots the cached `catalog` build headlessly via Playwright. One-time host
#    setup: `cd web && npx playwright install chromium`.
chore shoot: catalog
    sh -c 'npm --prefix web run shoot -- "${STORY:?set STORY=<story-id>, e.g. components--toycard--default}"'

# ── TESTS ────────────────────────────────────────────────────────────────────
chore test-core
    cargo test

chore test-web: deps
    npm --prefix web test

chore typecheck: deps
    npm --prefix web run typecheck

# Pre-commit umbrella: types + all three suites (core, web, backend).
chore check: typecheck test-core test-web server.test

chore fmt
    cargo fmt

# ── HOUSEKEEPING ─────────────────────────────────────────────────────────────
chore clean
    rm -rf target web/dist web/build web/.shots web/src/wasm/pkg .cook

chore distclean: clean
    rm -rf web/node_modules
