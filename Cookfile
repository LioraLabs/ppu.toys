# Cookfile for ppu.toys — a ShaderToy-style web playground for an emulated SNES PPU.
#
# Monorepo shape: a pure, headless Rust core (crates/ppu-core) compiled to WASM via
# wasm-pack, consumed by a React + Vite app (web/) behind the `PpuCore` TS seam.
#
#   ── build ──────────────────────────────────────────────────────────────────
#   cook             full build (default): WASM module + web/dist
#   cook build       same as above
#   cook wasm        (re)build the WASM module into web/src/wasm/pkg
#   cook web         production web build -> web/dist
#   cook deps        install web/node_modules
#
#   ── run ──────────────────────────────────────────────────────────────────────
#   cook dev         Vite dev server, mock core (no WASM build needed)
#   cook dev-wasm    Vite dev server against the real WASM core
#
#   ── verify ─────────────────────────────────────────────────────────────────
#   cook test-core   cargo test (core unit + golden framebuffer compare)
#   cook test-web    vitest
#   cook typecheck   tsc --noEmit over the web app
#   cook check       typecheck + both test suites (pre-commit umbrella)
#   cook fmt         cargo fmt
#
#   ── housekeeping ─────────────────────────────────────────────────────────────
#   cook clean       remove build artifacts (target, dist, wasm pkg, .cook cache)
#   cook distclean   clean + remove web/node_modules
#
# Caching: all three generated artifacts are content-cached recipes, so a no-op
# `cook build` is ~0s and `clean` + rebuild restores from cache.
#   - `wasm`  declares its files explicitly (its pkg lives inside web's source tree,
#             so a globbed directory output would collide with web's `web/src/**`
#             ingredient globs).
#   - `deps`  and `web` use DIRECTORY outputs (trailing `/`). This is safe now that
#             cook preserves symlinks + file modes on restore: node_modules'
#             `.bin/*` relative symlinks and Vite's content-hashed dist both round-trip
#             faithfully. Trade-off: a `deps` cache MISS (lockfile changed) empties
#             node_modules and does a full `npm install`; a cache HIT restores the tree
#             from the store. deps for THIS repo is npm (relative, in-tree symlinks) —
#             a pnpm repo (global-store hardlinks) would not be portable; keep it local.
#
# Cook gotcha: one command per line; a multi-step shell line needs `sh -c "a && b"`.

# ── WASM: rebuild the module only when the Rust core or its manifests change. The
#    files Vite + tsc consume are declared explicitly (so web forms file-level edges
#    to them). wasm-pack's --out-dir is relative to the crate dir.
recipe wasm
    ingredients "crates/ppu-core/src/**/*.rs" "crates/ppu-core/Cargo.toml" "Cargo.toml" "Cargo.lock"
    cook "web/src/wasm/pkg/ppu_core.js"
         "web/src/wasm/pkg/ppu_core_bg.wasm"
         "web/src/wasm/pkg/ppu_core.d.ts"
         "web/src/wasm/pkg/ppu_core_bg.wasm.d.ts" {
        wasm-pack build crates/ppu-core --target web --out-dir ../../web/src/wasm/pkg
    }

# ── DEPS: install node_modules as a cached directory output, keyed on the manifest
#    + lockfile. Relative `.bin/*` symlinks and exec bits round-trip.
recipe deps
    ingredients "web/package.json" "web/package-lock.json"
    cook "web/node_modules/" {
        npm --prefix web install --no-audit --no-fund
    }

# ── WEB: production bundle -> web/dist (cached directory output). Inputs are web's
#    sources/config, the lockfile (so a dep bump reaches the bundle), and the two
#    wasm pkg files Vite bundles (so a Rust change does too). cook owns the wasm
#    rebuild via the dep edge, so `build:app` (tsc + vite build) skips it.
recipe web: wasm deps
    ingredients "web/src/**/*.ts" "web/src/**/*.tsx" "web/index.html"
                "web/vite.config.ts" "web/tsconfig.json" "web/tsconfig.node.json"
                "web/package.json" "web/package-lock.json"
                "web/src/wasm/pkg/ppu_core.js" "web/src/wasm/pkg/ppu_core_bg.wasm"
    cook "web/dist/" {
        npm --prefix web run build:app
    }

# ── BUILD: the default target — the whole pipeline.
recipe build: web

# ── DEV SERVERS: long-running, interactive. Mock core by default; dev-wasm builds
#    the real module first and selects it via VITE_USE_WASM=1.
chore dev: deps
    npm --prefix web run dev

chore dev-wasm: wasm deps
    VITE_USE_WASM=1 npm --prefix web run dev

# ── TESTS ────────────────────────────────────────────────────────────────────
chore test-core
    cargo test

chore test-web: deps
    npm --prefix web test

chore typecheck: deps
    npm --prefix web run typecheck

# Pre-commit umbrella: types + both suites.
chore check: typecheck test-core test-web

chore fmt
    cargo fmt

# ── HOUSEKEEPING ─────────────────────────────────────────────────────────────
chore clean
    rm -rf target web/dist web/src/wasm/pkg .cook

chore distclean: clean
    rm -rf web/node_modules
