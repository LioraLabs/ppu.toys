# ppu-server environment — copy to /etc/ppu/ppu-server.env on the box and fill
# the blanks. Loaded by ppu-server.service via EnvironmentFile. NEVER commit a
# copy with real secret values. This whole file is the server's config surface.

# --- Server ---
PPU_PORT=8080
PPU_WEB_DIR=/opt/ppu/web/dist
PPU_DB_PATH=/var/lib/ppu/ppu.db
PPU_BLOB_MODE=db
PPU_DATA_DIR=/var/lib/ppu/blobs

# --- Discord OAuth (from the Discord Developer Portal app) ---
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://ppu.toys/api/auth/callback

# --- Discord publish bridge (#showcase channel webhook; unset = skipped) ---
DISCORD_WEBHOOK_URL=

# --- Admin / session / public URL ---
PPU_ADMIN_DISCORD_IDS=
PPU_SESSION_TTL_DAYS=30
PPU_BASE_URL=https://ppu.toys
