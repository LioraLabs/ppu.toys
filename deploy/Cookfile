# Cookfile for deploy/ production operations, imported by the root Cookfile as
# `deploy` (so: cook deploy.ship / deploy.rollback / deploy.health / deploy.logs).
#
# These are thin, env-driven wrappers around production operations. CI
# (.github/workflows/deploy.yml) owns the native x86_64 build and shipping;
# `deploy.ship` only triggers that workflow. Discord, Cloudflare, R2, and GitHub
# secret setup is manual dashboard work. Database restore is an operator procedure
# and is not automated here.
#
# Guards fail LOUDLY on missing env (`${VAR:?message}`) rather than running a
# broken ssh/curl — a missing input should never look like success.

# ── SHIP: trigger the CI deploy (build x86_64 + ship + restart runs on GitHub).
#    Requires `gh` auth and the workflow present on the default branch.
chore ship
    gh workflow run deploy.yml

# ── ROLLBACK: swap back to the previous binary kept by the last deploy. Needs
#    DEPLOY_HOST + DEPLOY_USER (same values as the GitHub deploy secrets).
chore rollback
    sh -c ': "${DEPLOY_HOST:?set DEPLOY_HOST}" "${DEPLOY_USER:?set DEPLOY_USER}"; ssh "$DEPLOY_USER@$DEPLOY_HOST" "sudo cp -a /opt/ppu/ppu-server.prev /opt/ppu/ppu-server && sudo systemctl restart ppu-server"'

# ── HEALTH: hit the live health endpoint. Override PPU_BASE_URL for staging/local.
chore health
    sh -c 'curl -fsS "${PPU_BASE_URL:-https://ppu.toys}/api/health" && echo'

# ── LOGS: follow the server journal on the box (Ctrl-C to stop). Set PPU_UNIT to
#    tail caddy/litestream instead of ppu-server.
chore logs
    sh -c ': "${DEPLOY_HOST:?set DEPLOY_HOST}" "${DEPLOY_USER:?set DEPLOY_USER}"; ssh -t "$DEPLOY_USER@$DEPLOY_HOST" "journalctl -u ${PPU_UNIT:-ppu-server} -f"'
